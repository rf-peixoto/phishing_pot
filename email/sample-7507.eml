      border-radius: 10px;
      box-shadow: 0 6px 18px rgba(0,63,125,0.06);
      border: 1px solid #dbe3ef;
    }

    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 18px;
      background-color: transparent;
      border-radius: 8px;
    }

    .header img {
      height: 44px;
      display: block;
    }

    .header a {
      background-color: #CE0E2D;
      color: #ffffff;
      text-decoration: none;
      padding: 8px 14px;
      border-radius: 20px;
      font-weight: 700;
      font-size: 13px;
      display: inline-block;
      box-shadow: 0 2px 6px rgba(206,14,45,0.18);
    }

    .confetti {
      font-size: 40px;
      margin: 20px 0;
    }

    h1 {
      font-size: 22px;
      margin: 6px 0 14px;
      color: #003F7D;
    }

    p {
      font-size: 15px;
      line-height: 1.5;
      margin-bottom: 12px;
      color: #2e3c4d;
    }

    .cta-button {
      background-color: #003F7D;
      color: #ffffff;
      text-decoration: none;
      padding: 12px 26px;
      border-radius: 28px;
      font-size: 15px;
      font-weight: 700;
      display: inline-block;
      border: 2px solid rgba(255,255,255,0.06);
      box-shadow: 0 6px 18px rgba(0,63,125,0.18);
    }

    .cta-button:active,
    .cta-button:focus {
      transform: translateY(1px);
      outline: none;
    }

    .secondary {
      display: inline-block;
      margin-left: 12px;
      font-size: 13px;
      color: #003F7D;
      text-decoration: none;
    }

    .footer {
      font-size: 13px;
      color: #66758b;
      margin-top: 20px;
      text-align: center;
    }

    .footer a {
      color: #003F7D;
      text-decoration: underline;
    }

    @media (max-width: 420px) {
      .container { padding: 16px; }
      .header img { height: 36px; }
      .cta-button { width: 100%; box-sizing: border-box; }
    }
  </style>
