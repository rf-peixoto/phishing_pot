<!DOCTYPE html><html lang="en"><head>
<meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Suspicious DEX Activity Alert</title>
    <style>
        /* Reset styles for email compatibility */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            line-height: 1.5;
            color: #E8EAED;
            background-color: #0D0F14;
            margin: 0;
            padding: 20px;
            -webkit-font-smoothing: antialiased;
        }
        
        /* Ledger 2024 Color Palette */
        .ledger-dark { color: #0D0F14; }
        .ledger-dark-bg { background-color: #0D0F14; }
        .ledger-surface { background-color: #1A1D26; }
        .ledger-card { background-color: #252935; }
        .ledger-primary { color: #8B5CF6; }
        .ledger-primary-bg { background-color: #8B5CF6; }
        .ledger-secondary { color: #3B82F6; }
        .ledger-accent { color: #10B981; }
        .ledger-warning { color: #F59E0B; }
        .ledger-error { color: #EF4444; }
        .ledger-text-primary { color: #E8EAED; }
        .ledger-text-secondary { color: #9CA3AF; }
        .ledger-border { border-color: #374151; }
        
        /* Email container */
        .email-container {
            max-width: 600px;
            margin: 0 auto;
            background-color: #1A1D26;
            border-radius: 16px;
            overflow: hidden;
            border: 1px solid #252935;
        }
        
        /* Header */
        .header {
            padding: 28px 32px;
            background: linear-gradient(135deg, #0D0F14 0%, #1A1D26 100%);
            text-align: center;
            border-bottom: 1px solid #252935;
        }
        
        .ledger-logo {
            width: 140px;
            height: auto;
        }
        
        .header-tag {
            display: inline-block;
            padding: 8px 16px;
            background-color: rgba(239, 68, 68, 0.1);
            color: #EF4444;
            font-size: 13px;
            font-weight: 700;
            border-radius: 6px;
            letter-spacing: 0.5px;
            border: 1px solid rgba(239, 68, 68, 0.3);
        }
        
        /* Content sections */
        .content {
            padding: 32px;
        }
        
        .alert-header {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 24px;
            padding-bottom: 20px;
            border-bottom: 1px solid #252935;
        }
        
        .alert-icon {
            width: 56px;
            height: 56px;
            background: linear-gradient(135deg, rgba(239, 68, 68, 0.1) 0%, rgba(239, 68, 68, 0.2) 100%);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
        
        .alert-icon svg {
            width: 28px;
            height: 28px;
            fill: #EF4444;
        }
        
        h1 {
            font-size: 24px;
            color: #E8EAED;
            margin-bottom: 8px;
            font-weight: 700;
            letter-spacing: -0.25px;
            line-height: 1.3;
        }
        
        .alert-subtitle {
            color: #9CA3AF;
            font-size: 15px;
            line-height: 1.4;
        }
        
        h2 {
            font-size: 18px;
            color: #E8EAED;
            margin: 28px 0 16px 0;
            font-weight: 700;
        }
        
        p {
            margin-bottom: 20px;
            color: #9CA3AF;
            font-size: 15px;
            line-height: 1.6;
        }
        
        /* DEX activity box */
        .dex-activity {
            background-color: #252935;
            border-radius: 12px;
            padding: 24px;
            margin: 28px 0;
            border: 1px solid #374151;
        }
        
        .activity-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 16px;
            border-bottom: 1px solid #374151;
        }
        
        .dex-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            background-color: #0D0F14;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            color: #E8EAED;
        }
        
        .risk-level {
            padding: 8px 14px;
            background-color: rgba(239, 68, 68, 0.1);
            color: #EF4444;
            border-radius: 6px;
            font-size: 13px;
            font-weight: 700;
            border: 1px solid rgba(239, 68, 68, 0.3);
        }
        
        .activity-details {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }
        
        .detail-item {
            margin-bottom: 16px;
        }
        
        .detail-label {
            font-size: 13px;
            color: #9CA3AF;
            margin-bottom: 6px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            font-weight: 600;
        }
        
        .detail-value {
            font-size: 15px;
            color: #E8EAED;
            font-weight: 500;
            word-break: break-word;
        }
        
        .token-amount {
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 600;
            flex-wrap: wrap;
        }
        
        /* Warning box */
        .warning-box {
            background: linear-gradient(135deg, rgba(245, 158, 11, 0.05) 0%, rgba(245, 158, 11, 0.1) 100%);
            border: 1px solid rgba(245, 158, 11, 0.3);
            border-radius: 12px;
            padding: 20px;
            margin: 28px 0;
        }
        
        .warning-title {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 12px;
            color: #F59E0B;
            font-weight: 700;
            font-size: 16px;
        }
        
        /* Action buttons */
        .action-buttons {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            margin: 32px 0;
        }
        
        .button {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 16px 24px;
            border-radius: 10px;
            font-weight: 600;
            text-decoration: none;
            text-align: center;
            font-size: 15px;
            transition: all 0.2s ease;
            border: none;
            cursor: pointer;
        }
        
        .button-primary {
            background: linear-gradient(135deg, #8B5CF6 0%, #3B82F6 100%);
            color: white;
        }
        
        .button-secondary {
            background-color: #252935;
            color: #E8EAED;
            border: 1px solid #374151;
        }
        
        /* Footer */
        .footer {
            padding: 28px 32px;
            background-color: #0D0F14;
            border-top: 1px solid #252935;
            font-size: 13px;
            color: #9CA3AF;
            text-align: center;
        }
        
        .security-tips {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 16px;
            margin: 24px 0;
            text-align: left;
        }
        
        .tip {
            background-color: #1A1D26;
            padding: 16px;
            border-radius: 8px;
            border: 1px solid #252935;
        }
        
        .tip-title {
            color: #E8EAED;
            font-weight: 700;
            margin-bottom: 8px;
            font-size: 14px;
        }
        
        .tip-content {
            font-size: 13px;
            line-height: 1.5;
        }
        
        .footer-links {
            margin-top: 24px;
            padding-top: 24px;
            border-top: 1px solid #252935;
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 16px;
        }
        
        .footer-links a {
            color: #8B5CF6;
            text-decoration: none;
            font-size: 13px;
            font-weight: 500;
        }
        
        .disclaimer {
            font-size: 12px;
            color: #6B7280;
            margin-top: 20px;
            line-height: 1.6;
            max-width: 500px;
            margin-left: auto;
            margin-right: auto;
        }
        
        /* Responsive adjustments */
        @media screen and (max-width: 480px) {
            body {
                padding: 12px;
            }
            
            .content, .header, .footer {
                padding: 24px 20px;
            }
            
            h1 {
                font-size: 22px;
            }
            
            .activity-details {
                grid-template-columns: 1fr;
            }
            
            .action-buttons {
                grid-template-columns: 1fr;
            }
            
            .security-tips {
                grid-template-columns: 1fr;
            }
            
            .activity-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 12px;
            }
            
            .alert-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 16px;
            }
            
            .ledger-logo {
                width: 120px;
            }
        }
    </style>
</head>
