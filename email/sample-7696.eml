<!DOCTYPE html><html lang="en"><head>
<meta http-equiv="Content-Type" content="text/html; charset=utf-8">
  <title>Bath &amp; Body Works – Exclusive Reward</title>
</head>
<body style="margin:0; padding:0; background-color:#F7F3EF; font-family:Arial, Helvetica, sans-serif; text-align:center;">

<table width="100%" cellpadding="0" cellspacing="0" style="padding:25px 0;">
  <tr>
    <td align="center">
      <table width="600" cellpadding="0" cellspacing="0" style="background:#ffffff; border-radius:12px; overflow:hidden;">
        
        <!-- HEADER -->
        <tr>
          <td align="center" style="background:#D9EFE6; padding:30px 20px;">
            <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/8/8e/Bath_%26_Body_Works_logo.svg/250px-Bath_%26_Body_Works_logo.svg.png" alt="Bath &amp; Body Works" width="180">
          </td>
        </tr>

        <!-- CONTENT -->
        <tr>
          <td style="padding:40px 35px; text-align:left;">
            <h1 style="font-size:24px; color:#0B6E4F; margin:0 0 20px; text-align:center;">
              Your Bath &amp; Body Works Rewards Is Waiting
            </h1>

            <p style="font-size:16px; line-height:1.6; color:#333; margin:0 0 20px;">
